<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Tesla Model X</title>
  <style>
    body {
      font-family: 'Segoe UI', sans-serif;
      background-color: #f4f6f8;
      margin: 0;
      padding: 20px;
    }

    .container {
      max-width: 1100px;
      margin: auto;
      background: white;
      padding: 30px;
      border-radius: 10px;
      box-shadow: 0 0 15px rgba(0,0,0,0.1);
    }

    h1, h2 {
      text-align: center;
      color: #333;
    }

    .main-image {
      width: 100%;
      border-radius: 10px;
      margin-bottom: 20px;
    }

    .price {
      font-size: 24px;
      color: #0078D7;
      text-align: center;
      margin-bottom: 20px;
    }

    .features ul {
      list-style: square;
      padding-left: 20px;
    }

    .gallery, .colors {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 15px;
      margin-top: 20px;
    }

    .gallery img, .colors img {
      width: 100%;
      border-radius: 8px;
      box-shadow: 0 0 10px rgba(0,0,0,0.1);
    }

    .view360 {
      text-align: center;
      margin-top: 30px;
    }

    .view360 a {
      text-decoration: none;
      color: white;
      background-color: #0078D7;
      padding: 10px 20px;
      border-radius: 5px;
      display: inline-block;
      transition: background-color 0.3s ease;
    }

    .view360 a:hover {
      background-color: #005bb5;
    }
    .view360 a {
        text-decoration: none;
        color: white;
        background-color: #0078D7;
        padding: 10px 20px;
        border-radius: 5px;
        display: inline-block;
        margin: 10px 5px; /* Adds spacing between buttons */
        transition: background-color 0.3s ease;
     }
      .view360 a {
          display: block;
          margin: 10px auto;
          width: fit-content;
       }

  </style>
</head>
<body>
  <div class="container">
    <h1>Tesla Model X</h1>
    

    <div class="price">Starting at ?65,02,000 (India)</div>

    <div class="features">
      <h2>Key Features</h2>
      <ul>
        <li>Dual Motor AWD with up to 670 HP</li>
        <li>Range: Up to 576 km (WLTP)</li>
        <li>Falcon Wing Doors</li>
        <li>17-inch Touchscreen Infotainment</li>
        <li>Autopilot & Full Self-Driving Capability</li>
        <li>Panoramic Windshield & Spacious Cabin</li>
        <li>360° Camera & Advanced Safety Suite</li>
      </ul>
    </div>

    <h2>Interior Gallery</h2>
    <div class="gallery">
      <img src="https://images.seattletimes.com/wp-content/uploads/2017/08/473db056-7944-11e7-9d40-beed802dbdca.jpg?d=2040x1273" alt="Dashboard">
      <img src="https://cdn-s3.autocarindia.com/tesla/model-x/Model-X_90.jpg?w=640&q=75" alt="Front Seats">
      <img src="https://static1.topspeedimages.com/wordpress/wp-content/uploads/2023/11/tesla-model3-interior-rear-shot.jpg" alt="Rear Seats">
      <img src="https://preview.redd.it/just-picked-up-our-2024-model-y-long-range-in-ultra-red-v0-e0na1r32sgkc1.jpg?width=640&crop=smart&auto=webp&s=7a7b15aa84c64615878b4916a9a6902774fe70e0" alt="Cargo Space">
    </div>
      <h2> Exterior Gallery</h2>
<div class="gallery">
      <img src="https://images.hgmsites.net/med/2019-tesla-model-s-p100d-awd-ltd-avail-front-exterior-view_100741369_m.jpg" alt="Front View">
      <img src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSOtw5g4-MWtOcBmCDVb0_fJwJR7KJj6Wba0g&s" alt="Side view">

    </div>
    

    
<h2>Available Colors</h2>
    <div class="colors">
      <img src="https://www.autobics.com/wp-content/uploads/2022/09/2022-Tesla-Model-X-Red-Multi-Coat.jpg" alt="Red Multi-Coat">
      <img src="https://www.autobics.com/wp-content/uploads/2022/09/2022-Tesla-Model-X-Deep-Blue-Metallic.jpg" alt="Deep Blue Metallic">
      <img src="https://www.autobics.com/wp-content/uploads/2022/09/2022-Tesla-Model-X-Midnight-Silver-Metallic.jpg" alt="Midnight Silver Metallic">
      <img src="https://www.autobics.com/wp-content/uploads/2022/09/2022-Tesla-Model-X-Pearl-White-Multi-Coat.jpg" alt="Pearl White Multi-Coat">
    </div>

    <div class="view360">
        <h2>360° Virtual Tour</h2>
        <a href="https://www.cardekho.com/tesla-model-x-360-view.htm" target="_blank">Launch 360° View</a>
        <form action="bookCar" method="post">
    <input type="hidden" name="carName" value="Tesla Model X">
    <button type="submit">Book Now</button>
</form>
        
    </div>


  </div>
    
</body>
</html>
